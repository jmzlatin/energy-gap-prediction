# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.python-version

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# --- IDE / editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Project-specific ---
# Cached external data pulls (regenerate from API)
data/external/cache/
*.parquet.cache

# Local experiment notebooks (use notebooks/ for shared work)
scratch/
experiments/

# Local secrets — never commit API keys
.env
.env.local
*.key
secrets.json

# Large model artifacts (regenerate from notebook)
*.pkl
*.joblib
models/

# Compiled outputs (rebuild from source)
paper/*.pdf
presentation/*.pdf

# --- Allowed exceptions ---
# Keep the base dataset (required for reproducibility, only 2MB)
!Data/sp500_Energy_dataset.csv

# Keep the official course instructions
!Instructions/*.pdf
